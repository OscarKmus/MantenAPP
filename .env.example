# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mantenti?schema=public"

# Auth
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@mantenti.local"

# PDF Branding
COMPANY_NAME="Mantenti"
COMPANY_LOGO_URL=""

# Admin Gate (min 12 characters — server refuses to start if shorter)
ADMIN_PASSWORD="change-me-admin-password-min-12-chars"
